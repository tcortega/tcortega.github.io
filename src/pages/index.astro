---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recent = sortedPosts.slice(0, config.posts.perIndex);
const latest =
  sortedPosts[0]?.data.modDatetime ?? sortedPosts[0]?.data.pubDatetime;

// Cross-reference the full archive only once the home index no longer shows
// everything.
const showArchiveLink =
  config.features.showArchives &&
  sortedPosts.length > config.posts.perIndex;
const archiveHref = getRelativeLocaleUrl(locale, "archives");
---

<Layout>
  <Header />
  <main id="main-content" class="page-body" data-layout="index">
    <h1 class="sr-only">
      {config.site.title} — {config.site.description}
    </h1>

    <div class="section-label">NAME</div>
    <div class="section-body" style="font: 400 14.5px/1.6 var(--font-body); color: var(--ink);">
      unstripped — reverse engineering notes, symbols included
    </div>

    <div class="section-label">DESCRIPTION</div>
    <p
      class="section-body measure"
      style="font: 400 14px/1.8 var(--font-body); color: var(--ink);"
    >
      A working notebook for taking software apart: long-form reverse-engineering
      write-ups, short notes from the debugger, and the occasional tutorial. No
      trackers, no popups, no cookie banner — just the disassembly and what it meant.
    </p>

    <div class="section-label">SYNOPSIS</div>
    <div
      class="synopsis-line"
      id="synopsis-filters"
      role="group"
      aria-label="Filter posts by category"
    >
      unstripped
      [<button type="button" data-filter="all" class="is-active">--all</button>]
      [<button type="button" data-filter="re">--re</button>]
      [<button type="button" data-filter="til">--til</button>]
      [<button type="button" data-filter="tut">--tut</button>]
    </div>

    <div class="section-label">INDEX</div>
    {
      recent.length > 0 ? (
        <ul class="index-list" id="post-index">
          {recent.map(post => (
            <Card {...post} />
          ))}
        </ul>
      ) : (
        <p class="section-body" style="color: var(--muted);">
          No posts yet.
        </p>
      )
    }

    {
      showArchiveLink && (
        <>
          <div class="section-label" style="margin-top: 30px;">
            SEE ALSO
          </div>
          <ul class="see-also">
            <li>
              <a href={archiveHref}>
                <span class="arrow">→</span>
                archive<span class="meta">(1)</span>
                <span class="meta"> — all {sortedPosts.length} posts</span>
              </a>
            </li>
          </ul>
        </>
      )
    }
  </main>
  <Footer updated={latest} />
</Layout>

<script>
  import "@/scripts/categoryFilter";
</script>

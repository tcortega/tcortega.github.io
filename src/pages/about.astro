---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const rssHref = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`;
const homeHref = getRelativeLocaleUrl(locale, "");
---

<Layout
  title={`about | ${config.site.title}`}
  description="About unstripped — who runs it, and why it exists."
>
  <Header />
  <main id="main-content" class="page-body">
    <a class="back-index" href={homeHref}>‹ index</a>

    <div class="section-label">NAME</div>
    <h1
      class="section-body"
      style="font: 600 22px/1.4 var(--font-body); color: var(--ink); letter-spacing: -0.01em;"
    >
      about — who runs unstripped, and why it exists
    </h1>

    <div class="section-label">DESCRIPTION</div>
    <p
      class="section-body tight measure"
      style="font: 400 14.5px/1.85 var(--font-body); color: var(--ink);"
    >
      I'm a developer and reverse engineer. unstripped is where I keep the notes
      I wish I'd found earlier — how a protector actually comes apart, what an
      anti-debug flag looks like in a disassembler, the one gdb trick that saved
      an afternoon.
    </p>
    <p
      class="section-body measure"
      style="font: 400 14.5px/1.85 var(--font-body); color: var(--ink);"
    >
      Long write-ups when a target earns them, short TILs when it doesn't.
      Everything here is hand-written and hand-broken — no trackers, no
      newsletter, no generated filler. If a post saved you an afternoon, that was
      the whole point.
    </p>

    <div class="section-label">TOPICS</div>
    <ul class="dash-list">
      <li>
        Reverse engineering &amp; unpacking — protectors, packers, import tables.
      </li>
      <li>Low-level debugging with gdb, IDA and rr.</li>
      <li>
        Anti-analysis tricks, and how to read them straight from the disassembly.
      </li>
    </ul>

    <div class="section-label">CONTACT</div>
    <div
      class="section-body last"
      style="font: 400 13.5px/1.6 var(--font-body); color: var(--muted);"
    >
      unstripped &nbsp;⟨<a
        href="mailto:hello@unstripped.dev"
        style="color: inherit;">hello@unstripped.dev</a
      >⟩ · <a href={rssHref} style="color: inherit;">rss</a> · <a
        href="https://github.com/tcortega"
        style="color: inherit;">@tcortega</a
      >
    </div>
  </main>
  <Footer centerLabel="about" />
</Layout>

---
import { type CollectionEntry, getCollection, render } from "astro:content";
import dayjs from "dayjs";
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPostSlug, getPostUrl } from "@/utils/getPostPaths";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { toTransitionName } from "@/utils/toTransitionName";
import {
  categoryKindLabel,
  readingTimeMinutes,
} from "@/utils/readingTime";
import BackButton from "./_components/BackButton.astro";
import AdjacentPostNav from "./_components/AdjacentPostNav.astro";
import config from "@/config";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sortedPosts = getSortedPosts(posts);

  return sortedPosts.map((post, index) => ({
    params: { slug: getPostSlug(post.id, post.filePath) },
    props: {
      post,
      index,
      prevPost:
        index > 0
          ? {
              id: sortedPosts[index - 1].id,
              title: sortedPosts[index - 1].data.title,
              filePath: sortedPosts[index - 1].filePath,
              index: index,
            }
          : null,
      nextPost:
        index < sortedPosts.length - 1
          ? {
              id: sortedPosts[index + 1].id,
              title: sortedPosts[index + 1].data.title,
              filePath: sortedPosts[index + 1].filePath,
              index: index + 2,
            }
          : null,
    },
  }));
}

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
  index?: number;
} | null;

type Props = {
  post: CollectionEntry<"posts">;
  index: number;
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { post, prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;

const {
  title,
  name,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  category = "re",
  synopsis,
} = post.data;

// Man-page NAME can be longer than the INDEX title.
const displayName = name ?? title;

const { Content } = await render(post);
const minutes = readingTimeMinutes(post.body);
const dateStr = dayjs(pubDatetime).format("YYYY-MM-DD");
const kind = categoryKindLabel(category);
const tagLine =
  tags.length > 0 ? ` · tags: ${tags.join(", ")}` : "";

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && config.features.dynamicOgImage) {
  const postUrl = getPostUrl(post.id, post.filePath, locale).replace(
    /\/+$/,
    ""
  );
  ogImageUrl = `${postUrl}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;
---

<PostLayout
  title={`${title} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
>
  <Header />

  <main id="main-content" class="page-body" data-pagefind-body>
    <BackButton />

    <div class="section-label">NAME</div>
    <h1
      class="section-body section-title"
      style={{ viewTransitionName: toTransitionName(title) }}
      data-pagefind-meta="title"
    >
      {displayName}
    </h1>

    <div class="section-label">SYNOPSIS</div>
    <div class="section-body section-meta">
      {
        synopsis && (
          <div style="color: var(--ink); margin-bottom: 0.35rem;">
            unstripped {synopsis}
          </div>
        )
      }
      <div style="color: var(--faint);">
        {dateStr} · {kind} · ~{minutes} min{tagLine}
      </div>
    </div>

    <div class="section-label">DESCRIPTION</div>
    <article
      id="article"
      class="app-prose"
      style="margin: 10px 0 0 28px; max-width: 64ch;"
    >
      <Content />
    </article>

    <AdjacentPostNav {prevPost} {nextPost} />

    <div class="section-label" style="margin-top: 26px;">AUTHOR</div>
    <div class="section-body last section-meta">
      unstripped &nbsp;⟨hello@unstripped.dev⟩
    </div>
  </main>
  <Footer updated={pubDatetime} />
</PostLayout>

<script>
  import "@/scripts/postEnhancements";
</script>

---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const homeHref = getRelativeLocaleUrl(locale, "");
---

<Layout title={`404 | ${config.site.title}`}>
  <Header />
  <main id="main-content" class="page-body">
    <div class="section-label">NAME</div>
    <h1 class="section-body section-title">404 — no such symbol</h1>

    <div class="section-label">DESCRIPTION</div>
    <p class="section-body measure section-prose">
      That path isn't in the symbol table. It may have been stripped, renamed, or
      never linked.
    </p>

    <div class="section-label">SEE ALSO</div>
    <ul class="see-also">
      <li>
        <a href={homeHref}>
          <span class="arrow">→</span>
          index
        </a>
      </li>
    </ul>
  </main>
  <Footer centerLabel="404" />
</Layout>

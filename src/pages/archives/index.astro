---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import CategoryFilter from "@/components/CategoryFilter.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostsByGroupCondition } from "./_utils/getPostsByGroupCondition";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Redirect to 404 page if `showArchives` config is false
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (!config.features.showArchives && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const homeHref = getRelativeLocaleUrl(locale, "");

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);

// Group by publication year, most recent year first. Within each year the
// order is inherited from getSortedPosts (recent-first), so no re-sort.
const years = Object.entries(
  getPostsByGroupCondition(sortedPosts, post =>
    post.data.pubDatetime.getFullYear()
  )
).sort(([yearA], [yearB]) => Number(yearB) - Number(yearA));
---

<Layout title={`archive | ${config.site.title}`}>
  <Header />
  <main id="main-content" class="page-body">
    <a class="back-index" href={homeHref}>‹ index</a>

    <div class="section-label">NAME</div>
    <h1 class="section-body section-name">
      archive — complete index, {sortedPosts.length} posts, most recent first
    </h1>

    <CategoryFilter />

    {
      years.map(([year, yearPosts]) => (
        <section
          class="archive-year-group"
          data-year-group
          aria-label={`Posts from ${year}`}
        >
          <div class="archive-year">
            <span class="archive-year-label">{year}</span>
            <span class="archive-year-rule" aria-hidden="true" />
          </div>
          <ul class="index-list">
            {yearPosts.map(post => (
              <Card {...post} />
            ))}
          </ul>
        </section>
      ))
    }
  </main>
  <Footer ref="archive" />
</Layout>

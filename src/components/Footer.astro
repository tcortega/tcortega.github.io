---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  /**
   * Man-page reference name shown in the footer centre, rendered as `name(1)`
   * (e.g. "archive" → archive(1)). Defaults to the site title.
   */
  ref?: string;
};

const { ref = config.site.title } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const rssHref = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`;
const aboutHref = getRelativeLocaleUrl(locale, "about");
const homeHref = getRelativeLocaleUrl(locale, "");
---

<footer class="site-footer">
  <div class="hairline" aria-hidden="true"></div>
  <div class="site-footer-inner">
    <a class="brand" href={homeHref}>unstripped.dev</a>
    <span class="man-ref">{ref}(1)</span>
    <span class="site-footer-links">
      {config.site.profile && <a href={config.site.profile}>github</a>}
      <a href={rssHref}>rss</a>
      <a href={aboutHref}>about</a>
    </span>
  </div>
</footer>

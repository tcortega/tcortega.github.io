---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import dayjs from "dayjs";
import config from "@/config";

type Props = {
  updated?: Date | string | null;
  centerLabel?: string;
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const {
  updated = null,
  centerLabel,
  noMarginTop: _,
  class: className,
  ...attrs
} = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const rssHref = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`;
const aboutHref = getRelativeLocaleUrl(locale, "about");
const homeHref = getRelativeLocaleUrl(locale, "");

const center = centerLabel
  ? centerLabel
  : updated
    ? `updated ${dayjs(updated).format("YYYY-MM-DD")}`
    : dayjs().format("YYYY-MM-DD");
---

<footer class:list={["site-footer", className]} {...attrs}>
  <div class="hairline" aria-hidden="true"></div>
  <div class="site-footer-inner">
    <a class="brand" href={homeHref}>unstripped.dev</a>
    <span>{center}</span>
    <span class="site-footer-links">
      <a href={rssHref}>rss</a>
      <a href={aboutHref}>about</a>
    </span>
  </div>
</footer>

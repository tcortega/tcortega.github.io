---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<a
  id="skip-to-content"
  href="#main-content"
  class="bg-paper text-accent absolute inset-s-16 -top-full z-50 px-3 py-2 transition-all focus:top-4"
>
  Skip to content
</a>

<header class="site-header">
  <div class="site-header-inner">
    <a href={getRelativeLocaleUrl(locale, "")} class="site-wordmark">
      unstripped.dev
    </a>

    {
      config.features.lightAndDarkMode && (
        <div class="theme-toggle" role="group" aria-label="Color theme">
          <button type="button" data-theme-set="light" aria-pressed="true">
            light
          </button>
          <span class="sep" aria-hidden="true">/</span>
          <button type="button" data-theme-set="dark" aria-pressed="false">
            dark
          </button>
        </div>
      )
    }
  </div>
  <div class="hairline" aria-hidden="true"></div>
</header>

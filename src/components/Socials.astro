---
import config from "@/config";

const { site, socials } = config;

// Text labels, not icons — they read as part of the mono UI rather than chrome.
const items = socials.map(({ name, url, linkTitle }) => {
  const title =
    linkTitle ??
    (url.startsWith("mailto:") || name === "mail"
      ? `Send an email to ${site.title}`
      : `${site.title} on ${name.charAt(0).toUpperCase() + name.slice(1)}`);
  return { url, title, label: name.toLowerCase() };
});
---

<div class="font-app flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
  {
    items.map(({ url, title, label }) => (
      <a
        href={url}
        title={title}
        target={url.startsWith("http") ? "_blank" : undefined}
        rel={url.startsWith("http") ? "noopener noreferrer" : undefined}
        class="text-muted-foreground hover:text-accent transition-colors"
      >
        {label}
      </a>
    ))
  }
</div>

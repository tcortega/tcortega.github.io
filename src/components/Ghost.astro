---
/**
 * The ghost — `.text`'s mascot. The "ghost in the binary": what you're chasing
 * when you reverse a stripped, obfuscated program. A tiny 1-bit pixel sprite
 * (crispEdges, no anti-aliasing) so it reads as deliberate pixel art at any size.
 *
 * Body = currentColor (set by the parent); eyes = the crimson accent. Decorative
 * — always paired with real text.
 */
type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 9 9"
  shape-rendering="crispEdges"
  fill="currentColor"
  aria-hidden="true"
  class:list={["ghost", className]}
>
  <!-- domed top → body -->
  <rect x="3" y="0" width="3" height="1" />
  <rect x="2" y="1" width="5" height="1" />
  <rect x="1" y="2" width="7" height="2" />
  <rect x="0" y="4" width="9" height="4" />
  <!-- wavy hem (notches at x=2 and x=6) -->
  <rect x="0" y="8" width="2" height="1" />
  <rect x="3" y="8" width="3" height="1" />
  <rect x="7" y="8" width="2" height="1" />
  <!-- crimson eyes -->
  <rect x="2" y="4" width="1" height="2" fill="var(--accent)" />
  <rect x="6" y="4" width="1" height="2" fill="var(--accent)" />
</svg>

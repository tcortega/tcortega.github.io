---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";

type Props = CollectionEntry<"posts">;

const { id, data, filePath } = Astro.props;
const { title, pubDatetime, category = "re" } = data;
const href = getPostUrl(id, filePath, Astro.currentLocale);
const dateStr = dayjs(pubDatetime).format("YYYY-MM-DD");
---

<li>
  {/* Exact prototype row: date | title | dotted leader (flex:1) | cat */}
  <a href={href} class="index-row" data-category={category}>
    <span class="index-date">
      <time datetime={new Date(pubDatetime).toISOString()}>{dateStr}</time>
    </span>
    <span
      class="index-title"
      style={{ viewTransitionName: toTransitionName(title) }}
    >
      {title}
    </span>
    <span class="index-leader" aria-hidden="true"></span>
    <span class="index-cat">{category}</span>
  </a>
</li>

---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "font-app border-border bg-raised text-muted-foreground inline-flex items-center gap-0.5 rounded-sm border px-2 py-0.5",
      "hover:border-accent hover:text-accent focus-visible:text-accent transition-colors",
      { "text-xs": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    <span class="text-accent/70" aria-hidden="true">#</span>{tagName}
  </a>
</li>
